{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "swift *": "allow",
      "swift build *": "allow",
      "swift package *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git add *": "allow",
      "git commit *": "allow",
      "git tag *": "allow",
      "git push *": "ask",
      "codesign *": "allow",
      "ditto *": "allow",
      "sips *": "allow",
      "iconutil *": "allow",
      "cp *": "allow",
      "mkdir *": "allow",
      "rm *": "ask",
      "chmod *": "allow",
      "open *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "security *": "allow",
      "defaults *": "allow",
      "killall *": "ask",
      "sudo *": "ask",
      "gh auth *": "ask",
      "gh release *": "ask",
      "gh pr *": "ask",
      "gh *": "deny"
    }
  }
}
